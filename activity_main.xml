<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/activity_main.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="StudyMate AI"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Your Class"
            android:textSize="18sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingBottom="32dp" />

        <!-- Class 8 Button -->
        <Button
            android:id="@+id/btn_class8"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Class 8"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="16dp" />

        <!-- Class 9 Button -->
        <Button
            android:id="@+id/btn_class9"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Class 9"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="16dp" />

        <!-- Class 10 Button -->
        <Button
            android:id="@+id/btn_class10"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Class 10"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="16dp" />

        <!-- Class 11 Button -->
        <Button
            android:id="@+id/btn_class11"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Class 11"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="16dp" />

        <!-- Class 12 Button -->
        <Button
            android:id="@+id/btn_class12"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Class 12"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
